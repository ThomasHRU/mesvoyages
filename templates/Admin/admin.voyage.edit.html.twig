{% extends "baseadmin.html.twig" %}

{% block body %}
    <h2>{{ visite.ville }}</h2>

    {{ form_start(formVisite) }}
    <div class="row">
        <div class="col">
            <div class="row">
                <div class="col-auto">
                    {{ form_row(formVisite.datecreation) }}
                </div>
                <div class="col">
                    {{ form_row(formVisite.note) }}
                </div>
                <div class="col">
                    {{ form_row(formVisite.tempmin) }}
                </div>
                <div class="col">
                    {{ form_row(formVisite.tempmax) }}
                </div>
                {{ form_row(formVisite.ville) }}
                {{ form_row(formVisite.pays) }}
            </div>
        </div>
        <div class="col">
        </div>
    </div>

    <div class="row">
        <div class="col">
            {{ form_row(formVisite.avis) }}
        </div>
    </div>
    {{ form_end(formVisite) }}
{% endblock %}