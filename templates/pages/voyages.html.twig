{% extends "basefront.html.twig" %}

{% block body %}
    <table class="table table-striped">
        <thead>
            <tr>
                <th scope="col"> Ville
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "ville", order: "ASC"}) }} "
                        role="button"
                        > < </a>
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "ville", order: "DESC"}) }} "
                        role="button"
                        > > </a>
                </th>
                <th scope="col"> Pays
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "pays", order: "ASC"}) }} "
                        role="button"
                        > < </a>
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "pays", order: "DESC"}) }} "
                        role="button"
                        > > </a></th>
                <th scope="col"> Note
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "note", order: "ASC"}) }} "
                        role="button"
                        > < </a>
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "note", order: "DESC"}) }} "
                        role="button"
                        > > </a></th>
                <th scope="col"> Date
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "datecreation", order: "ASC"}) }} "
                        role="button"
                        > < </a>
                    <a 
                        class="btn btn-primary"
                        href=" {{ path("villeSort", {champ: "datecreation", order: "DESC"}) }} "
                        role="button"
                        > > </a></th>
            </tr>
        </thead>
        <tbody>
            {% for visite in visites %}
                <tr>
                    <th scope="row"> <a href="#"> {{ visite.ville }} </a> </th>
                    <td> {{ visite.pays }} </td>
                    <td>
                        <strong>
                            {% if visite.note < 10 %}
                                <div class="text-danger"> {{ visite.note }}/20 </div>
                            {% else %}
                                <div class="text-success"> {{ visite.note }}/20 </div>
                            {% endif %}
                        </strong>
                    </td>
                    <td> {{ visite.datecreationstring }} </td>
                </tr>
            {% endfor %}
        </tbody>
    </table>

{% endblock %}